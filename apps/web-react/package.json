{
  "name": "web-react",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@11.6.0",
  "type": "module",
  "engines": {
    "node": ">=24.16",
    "pnpm": "11.6.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5178 --strictPort",
    "dev:e2e": "vite --host 127.0.0.1 --port 5179 --strictPort",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4178 --strictPort",
    "preview:e2e": "vite preview --host 127.0.0.1 --port 5179 --strictPort",
    "check": "tsc -b --pretty false",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "api:gen": "openapi-typescript ${SEEKTALENT_OPENAPI_URL:-http://127.0.0.1:8012/openapi.json} -o src/lib/api/schema.d.ts && prettier --write src/lib/api/schema.d.ts",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "storybook:a11y": "playwright test --config playwright.storybook.config.ts tests/storybook-a11y.spec.ts",
    "storybook:interactions": "playwright test --config playwright.storybook.config.ts tests/storybook-interactions.spec.ts",
    "storybook:visual": "playwright test --config playwright.storybook-visual.config.ts"
  },
  "dependencies": {
    "@jackwener/opencli": "1.8.3",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "@xyflow/react": "^12.11.0",
    "elkjs": "^0.11.1",
    "lucide-react": "^1.17.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@storybook/addon-a11y": "^10.4.4",
    "@storybook/react-vite": "^10.4.4",
    "@tanstack/router-devtools": "^1.167.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "axe-core": "^4.12.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.4",
    "storybook": "^10.4.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
